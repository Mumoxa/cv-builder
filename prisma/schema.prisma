generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidateProfile CandidateProfile?
  evidence          Evidence[]
}

model CandidateProfile {
  id     String @id @default(cuid())
  userId String @unique

  hasVerifiedEvidence Boolean @default(false)

  evidenceCompletenessScore Float @default(0)
  cvConfidenceScore         Float @default(0)
  credibilityScore          Float @default(0)

  cvData Json?
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Evidence {
  id     String @id @default(cuid())
  userId String

  fileUrl String
  fileKey String

  type   EvidenceType
  status EvidenceStatus @default(PENDING)

  score   Float?
  version Int    @default(1)

  rawText         String? @db.Text
  extractedData   Json?
  rejectionReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  moderationLogs ModerationLog[]
}

model ModerationLog {
  id         String @id @default(cuid())
  evidenceId String

  agentName       AgentName
  action          String
  reasoning       String @db.Text
  confidenceScore Float
  rawOutput       Json

  createdAt DateTime @default(now())

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
}

enum EvidenceType {
  CV
  ID
  DIPLOMA
  CERTIFICATION
  ASSESSMENT_RESULT
  EMPLOYMENT_PROOF
  REFERENCE
  PORTFOLIO
  OTHER
}

enum EvidenceStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  FAILED
}

enum AgentName {
  Extractor
  Validator
  Compliance
  Scorer
  Moderator
  System
}
